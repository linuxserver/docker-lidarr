#!/usr/bin/with-contenv bash
# shellcheck shell=bash

PORT=8686

if [[ -f /config/config.xml ]]; then
    PORT=$(xmlstarlet sel \
        -T \
        -t \
        -v /Config/Port \
        /config/config.xml 2>/dev/null || echo 8686)
fi

STATUS=$(curl \
    --silent \
    --fail \
    --max-time 5 \
    "http://localhost:${PORT}/ping" \
    | jq -r '.status' 2>/dev/null)

[[ "${STATUS}" == "OK" ]]